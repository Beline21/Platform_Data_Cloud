AIRFLOW_IMAGE_NAME=apache/airflow:3.1.7
AIRFLOW_UID=50000

# Metadatabase
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://svc_airflow:<MOT_DE_PASSE>@postgres:5432/airflow

# Celery
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://svc_airflow:<MOT_DE_PASSE>@postgres:5432/airflow
AIRFLOW__CELERY__BROKER_URL=redis://redis:6379/0

# Web UI
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Security
AIRFLOW__CORE__FERNET_KEY=<FERNET_KEY>
